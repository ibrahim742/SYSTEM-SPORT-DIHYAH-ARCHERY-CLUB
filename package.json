{
  "name": "altlit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "start:cpanel": "node server.js",
    "lint": "next lint",
    "cache:clean": "rm -rf .next",
    "db:audit:mysql": "tsx scripts/audit-mysql-migration.ts",
